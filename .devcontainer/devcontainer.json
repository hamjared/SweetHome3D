{
  "name": "Sweet Home 3D Dev",
  "dockerComposeFile": "docker-compose.yml",
  "service": "sweethome-dev",
  "workspaceFolder": "/workspace",
  "customizations": {
    "vscode": {
      "extensions": [
        "redhat.java",
        "vscjava.vscode-maven",
        "vscjava.vscode-java-debug",
        "vscjava.vscode-java-test"
      ],
      "settings": {
        "java.home": "/opt/java/openjdk",
        "java.jdt.ls.vmargs": "-XX:+UseParallelGC -XX:GCHeapFreePercent=30 -XX:GCMaxHeapFreePercent=40 -Xmx2048m",
        "[java]": {
          "editor.defaultFormatter": "redhat.java",
          "editor.formatOnSave": true
        }
      }
    }
  },
  "remoteUser": "root",
  "forwardPorts": [5901, 6000],
  "portsAttributes": {
    "5901": {
      "label": "VNC Server",
      "onAutoForward": "notify"
    },
    "6000": {
      "label": "X11",
      "onAutoForward": "ignore"
    }
  },
  "postCreateCommand": "echo '✓ Sweet Home 3D dev environment ready. Run: ant build' && ant -version",
  "remoteEnv": {
    "JAVA_HOME": "/opt/java/openjdk"
  }
}
